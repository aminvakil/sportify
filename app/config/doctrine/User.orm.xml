<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity repository-class="Devlabs\SportifyBundle\Entity\UserRepository" name="Devlabs\SportifyBundle\Entity\User" table="users">
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="username" type="string" column="username" length="180" nullable="false"/>
    <field name="usernameCanonical" type="string" column="username_canonical" length="180" unique="true" nullable="false"/>
    <field name="email" type="string" column="email" length="180" nullable="false"/>
    <field name="emailCanonical" type="string" column="email_canonical" length="180" unique="true" nullable="false"/>
    <field name="enabled" type="boolean" column="enabled" nullable="false"/>
    <field name="salt" type="string" column="salt" nullable="true"/>
    <field name="password" type="string" column="password" nullable="false"/>
    <field name="lastLogin" type="datetime" column="last_login" nullable="true"/>
    <field name="confirmationToken" type="string" column="confirmation_token" length="180" unique="true" nullable="true"/>
    <field name="passwordRequestedAt" type="datetime" column="password_requested_at" nullable="true"/>
    <field name="roles" type="array" column="roles" nullable="false"/>
    <field name="slackUsername" type="string" column="slack_username" length="100" nullable="false"/>
    <one-to-many field="scores" target-entity="Score" mapped-by="userId" fetch="LAZY">
      <cascade>
        <cascade-all/>
      </cascade>
    </one-to-many>
    <one-to-many field="predictions" target-entity="Prediction" mapped-by="userId" fetch="LAZY">
      <cascade>
        <cascade-all/>
      </cascade>
    </one-to-many>
    <one-to-many field="predictionsChampion" target-entity="PredictionChampion" mapped-by="userId" fetch="LAZY">
      <cascade>
        <cascade-all/>
      </cascade>
    </one-to-many>
  </entity>
</doctrine-mapping>
