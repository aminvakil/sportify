<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity repository-class="Devlabs\SportifyBundle\Entity\TeamRepository" name="Devlabs\SportifyBundle\Entity\Team" table="teams">
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="name" type="string" column="name" length="100" unique="true" nullable="false"/>
    <one-to-many field="predictionsChampion" target-entity="PredictionChampion" mapped-by="teamId" fetch="LAZY">
      <cascade>
        <cascade-all/>
      </cascade>
    </one-to-many>
    <one-to-many field="tournamentsChampion" target-entity="Tournament" mapped-by="championTeamId" fetch="LAZY">
      <cascade>
        <cascade-all/>
      </cascade>
    </one-to-many>
    <one-to-many field="matchesHomeTeam" target-entity="MatchEntity" mapped-by="homeTeamId" fetch="LAZY">
      <cascade>
        <cascade-all/>
      </cascade>
    </one-to-many>
    <one-to-many field="matchesAwayTeam" target-entity="MatchEntity" mapped-by="awayTeamId" fetch="LAZY">
      <cascade>
        <cascade-all/>
      </cascade>
    </one-to-many>
    <many-to-many field="tournaments" target-entity="Tournament" inversed-by="teams" fetch="LAZY">
      <join-table name="teams_tournaments">
        <join-columns>
          <join-column name="team_id" referenced-column-name="id" on-delete="CASCADE"/>
        </join-columns>
        <inverse-join-columns>
          <join-column name="tournament_id" referenced-column-name="id" on-delete="CASCADE"/>
        </inverse-join-columns>
      </join-table>
    </many-to-many>
  </entity>
</doctrine-mapping>
