<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity repository-class="Devlabs\SportifyBundle\Entity\PredictionChampionRepository" name="Devlabs\SportifyBundle\Entity\PredictionChampion" table="predictions_champion">
    <unique-constraints>
      <unique-constraint name="user_tournament" columns="user_id,tournament_id"/>
    </unique-constraints>
    <id name="id" type="integer" column="id">
      <generator strategy="IDENTITY"/>
    </id>
    <field name="points" type="integer" column="points" nullable="true"/>
    <field name="scoreAdded" type="boolean" column="score_added" nullable="false"/>
    <many-to-one field="userId" target-entity="User" inversed-by="predictionsChampion" fetch="LAZY">
      <join-columns>
        <join-column name="user_id" referenced-column-name="id" nullable="true"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="tournamentId" target-entity="Tournament" inversed-by="predictionsChampion" fetch="LAZY">
      <join-columns>
        <join-column name="tournament_id" referenced-column-name="id" nullable="true"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="teamId" target-entity="Team" inversed-by="predictionsChampion" fetch="LAZY">
      <join-columns>
        <join-column name="team_id" referenced-column-name="id" nullable="true"/>
      </join-columns>
    </many-to-one>
  </entity>
</doctrine-mapping>
