# This file is a "template" of what your parameters.yml file should look like
parameters:
    # db
    database_host:     127.0.0.1
    database_port:     ~
    database_name:     symfony
    database_user:     root
    database_password: ~

    # mail
    # Put SMTP username/password in the DSN before the host:
    # smtp://USERNAME:PASSWORD@SMTP_HOST:PORT
    # Example for username "user@example.com" and password "app-password":
    # smtp://user%40example.com:app-password@smtp.example.com:587
    # Only encode special characters inside USERNAME/PASSWORD.
    # The @ before SMTP_HOST separates credentials from host, so keep it as @.
    mailer_dsn:        smtp://127.0.0.1:587
    mailer_sender_address: change-me@example.com

    # secret used for generating security-related tokens
    secret:            ThisTokenIsNotSoSecretChangeIt

    # football API token
    # get football-data.org API token by FREE registration here: http://www.football-data.org/register
    football_api.token: check_the_README_file
    # The Odds API token for imported fixture probabilities
    odds_api.token: check_the_README_file
    # Slack webhook URL
    slack.url: check_the_README_file
    # Slack channel to which notifications will be sent
    slack.channel: check_the_README_file
    # Telegram bot token for scheduled notifications
    telegram.bot_token: check_the_README_file
    # Telegram chat id for scheduled notifications
    telegram.chat_id: check_the_README_file
    # Pin Telegram data update notifications after sending
    telegram.pin_messages: true

    # sportify API params used for generating tokens
    sportify_api.client_id:     ~
    sportify_api.client_secret: ~