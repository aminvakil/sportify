{% extends 'base.html.twig' %}

{% block nav_top %}
    <h1 class="text-center">Admin panel</h1>
{% endblock %}

{% block body %}

    <div class="container-fluid content admin-page">
        <div class="row">
            <div class="col-lg-12 col-md-12">
                <h2 class="text-center">Default base scoring</h2>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-4 col-lg-offset-4 col-md-6 col-md-offset-3 col-sm-8 col-sm-offset-2">
                <div class="panel panel-default">
                    <div class="panel-body">
                        <p class="text-muted">
                            These defaults are applied to newly added matches. Existing matches keep their stored scoring values.
                        </p>
                        {{ form_start(form) }}
                            {{ form_errors(form) }}
                            <div class="form-group">
                                {{ form_label(form.outcomePoints) }}
                                {{ form_errors(form.outcomePoints) }}
                                {{ form_widget(form.outcomePoints, {'attr': {'class': 'form-control' } }) }}
                            </div>
                            <div class="form-group">
                                {{ form_label(form.exactPoints) }}
                                {{ form_errors(form.exactPoints) }}
                                {{ form_widget(form.exactPoints, {'attr': {'class': 'form-control' } }) }}
                            </div>
                            <div class="text-center">
                                {{ form_widget(form.button, {'attr': {'class': 'btn green-btn' } }) }}
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
